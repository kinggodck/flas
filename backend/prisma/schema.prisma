generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_DIRECT")
}

model Factory {
  id           Int             @id @default(autoincrement())
  code         String          @unique
  name         String
  totalAreaSqm Float?
  zones        Zone[]
  changeLogs   AreaChangeLog[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model Zone {
  id               Int              @id @default(autoincrement())
  factoryId        Int
  factory          Factory          @relation(fields: [factoryId], references: [id])
  name             String
  availableAreaSqm Float
  usageType        String?
  dimensions       String?
  isActive         Boolean          @default(true)
  assignments      AreaAssignment[]
  changeLogs       AreaChangeLog[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([factoryId, name])
}

model AreaChangeLog {
  id         Int      @id @default(autoincrement())
  entityType String
  entityId   Int
  fieldName  String
  oldValue   String?
  newValue   String?
  changedBy  String?
  changedAt  DateTime @default(now())
  factory    Factory? @relation(fields: [factoryId], references: [id])
  factoryId  Int?
  zone       Zone?    @relation(fields: [zoneId], references: [id])
  zoneId     Int?
}

model Project {
  id               Int              @id @default(autoincrement())
  projectNo        String           @unique
  clientName       String?
  description      String?
  businessDivision String?          // 사업부문 (플랜트 BU, 방산 BU, 중공업 BU, ...)
  status           String           @default("active")
  assignments      AreaAssignment[]
  items            ProjectItem[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model ProjectItem {
  id           Int      @id @default(autoincrement())
  projectId    Int
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  itemName     String
  itemCategory String?
  widthM       Float
  heightM      Float
  quantity     Int      @default(1)
  marginRate   Float    @default(0)  // % (예: 10 → 10%)
  unitAreaSqm  Float                 // widthM × heightM
  totalAreaSqm Float                 // unitAreaSqm × quantity × (1 + marginRate/100)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AreaAssignment {
  id              Int                 @id @default(autoincrement())
  projectId       Int
  project         Project             @relation(fields: [projectId], references: [id])
  zoneId          Int
  zone            Zone                @relation(fields: [zoneId], references: [id])
  startDate       DateTime
  endDate         DateTime
  requiredAreaSqm Float               // 단일 구간이면 전체 기간 면적, 2구간이면 1구간 면적
  widthM          Float?
  heightM         Float?
  quantity        Int?
  marginRate      Float?              // % (예: 10 → 10%)
  status          String              @default("confirmed")
  notes           String?
  segments        AreaDemandSegment[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

// 2구간 조립 공간 스케줄: phaseNo 1(초기 대면적) / 2(후반 축소면적)
model AreaDemandSegment {
  id                Int            @id @default(autoincrement())
  assignmentId      Int
  assignment        AreaAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  phaseNo           Int            // 1 or 2
  startDate         DateTime
  endDate           DateTime
  widthM            Float
  heightM           Float
  quantity          Int            @default(1)
  marginRate        Float          @default(0)
  calculatedAreaSqm Float          // widthM × heightM × quantity × (1 + marginRate/100)
  createdAt         DateTime       @default(now())
}
